---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  meta?: string;
}
const {
  title = '论文速递',
  description = '每日个性化 arxiv 论文筛选与推送',
  meta,
} = Astro.props;

const fullTitle = title === '论文速递' ? title : `${title} · 论文速递`;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!doctype html>
<html lang="zh">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fdfdfb" />
    <title>{fullTitle}</title>

    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  </head>
  <body>
    <header class="topbar">
      <a class="brand" href={`${base}/`}>论文速递</a>
      <span class="meta">{meta ?? 'paper · brief'}</span>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-foot">
      <span>paper-brief · {new Date().getUTCFullYear()}</span>
    </footer>
  </body>
</html>
