---
import '../styles/global.css';
import CyberFx from '../components/CyberFx.astro';

interface Props {
  title?: string;
  description?: string;
  meta?: string;
}
const {
  title = '论文速递',
  description = '每日个性化 arxiv 论文筛选与推送',
  meta,
} = Astro.props;

const fullTitle = title === '论文速递' ? title : `${title} · 论文速递`;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!doctype html>
<html lang="zh">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0f" />
    <title>{fullTitle}</title>

    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Share+Tech+Mono&display=swap"
    />
  </head>
  <body data-theme="cyberpunk">
    <CyberFx />

    <header class="topbar">
      <a class="brand" href={`${base}/`}>论文速递</a>
      <span class="meta">{meta ?? 'PAPER · BRIEF'}</span>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-foot">
      <span>// PAPER-BRIEF · CYBERPUNK BUILD · {new Date().getUTCFullYear()}</span>
    </footer>

    <script>
      import '../scripts/cursor.ts';
    </script>
  </body>
</html>
