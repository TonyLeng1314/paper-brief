---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PaperCard from '../../components/PaperCard.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { date: post.data.date },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'posts'>;
}
const { post } = Astro.props;
const { date, kept, reviewed, min_score, papers } = post.data;
---
<Base title={date} meta={`BRIEF · ${date}`}>
  <article class="day">
    <header class="day-header">
      <h1>{date}</h1>
      <p class="stats">
        推送 <em>{kept}</em> 篇 · 共审阅 <em>{reviewed}</em> 篇候选 (score ≥ <em>{min_score}</em>)
      </p>
    </header>

    <div class="paper-list">
      {papers.map((paper) => <PaperCard paper={paper} />)}
    </div>
  </article>
</Base>
