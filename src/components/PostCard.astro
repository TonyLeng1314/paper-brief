---
interface Paper {
  title_zh?: string;
  title: string;
}
interface PostData {
  date: string;
  kept: number;
  reviewed: number;
  min_score: number;
  papers: Paper[];
}
interface Props {
  data: PostData;
}
const { data } = Astro.props;
const top = data.papers[0];
const preview = top ? top.title_zh || top.title : '';
const href = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/posts/${data.date}/`;
---
<a class="post-card" href={href} aria-label={`${data.date} 论文速递`}>
  <time datetime={data.date}>{data.date}</time>
  <p class="post-stats">
    推送 {data.kept} 篇 · 共审 {data.reviewed} 篇
  </p>
  {preview && <p class="post-preview">{preview}</p>}
  <span class="post-arrow">VIEW →</span>
</a>
