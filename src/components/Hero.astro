---
interface Props {
  title?: string;
  tag?: string;
  sub?: string;
}
const {
  title = '论文速递',
  tag = 'daily · arxiv · triage',
  sub = '每日从 arXiv、HuggingFace Papers 与关注作者动态中筛选,由大模型打分并写中文摘要。',
} = Astro.props;
---
<section class="cyber-hero">
  <p class="hero-tag">{tag}</p>
  <h1>{title}</h1>
  <p class="hero-sub">{sub}</p>
</section>
