---
interface Props {
  title?: string;
  tag?: string;
  sub?: string;
}
const {
  title = '论文速递',
  tag = 'DAILY · ARXIV · TRIAGE',
  sub = '每日个性化论文筛选与推送',
} = Astro.props;
---
<section class="cyber-hero">
  <h1 data-text={title}>{title}</h1>
  <p class="hero-tag">{tag}</p>
  <p class="hero-sub">{sub}</p>
</section>
