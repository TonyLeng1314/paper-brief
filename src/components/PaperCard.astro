---
interface Paper {
  rank: number;
  title: string;
  title_zh?: string;
  score: number;
  authors: string[];
  source: string;
  arxiv_id: string | null;
  url: string;
  published: string | null;
  tldr: string;
  why: string;
  hits: string[];
}
interface Props {
  paper: Paper;
}
const { paper } = Astro.props;
const zh = paper.title_zh && paper.title_zh.trim() ? paper.title_zh : paper.title;
const authorsDisplay =
  paper.authors.length <= 5
    ? paper.authors.join(', ')
    : `${paper.authors.slice(0, 5).join(', ')}, … (+${paper.authors.length - 5})`;
---
<article class="paper-card" data-score={paper.score}>
  <header class="paper-head">
    <span class="paper-rank">#{paper.rank.toString().padStart(2, '0')}</span>
    <span class="score-badge">{paper.score}/10</span>
  </header>

  <h2>{zh}</h2>
  {paper.title_zh && paper.title_zh.trim() && paper.title_zh !== paper.title && (
    <p class="title-en">{paper.title}</p>
  )}

  <p class="meta">
    <strong>作者</strong>{authorsDisplay}
  </p>
  <p class="meta">
    <strong>来源</strong><code>{paper.source}</code>
    {paper.arxiv_id && (
      <>
        <span class="sep">·</span>
        <strong>arXiv</strong>
        <a href={paper.url} target="_blank" rel="noopener noreferrer">
          <code>{paper.arxiv_id}</code>
        </a>
      </>
    )}
    {paper.published && (
      <>
        <span class="sep">·</span>
        <strong>发布</strong>{paper.published}
      </>
    )}
  </p>

  <div class="body">
    <p><strong>摘要.</strong>{paper.tldr}</p>
    <p><strong>为什么相关.</strong>{paper.why}</p>
  </div>

  {paper.hits.length > 0 && (
    <div class="hits">
      {paper.hits.map((h) => <span class="hit">{h}</span>)}
    </div>
  )}
</article>
