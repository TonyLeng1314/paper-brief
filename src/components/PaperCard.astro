---
interface Deep {
  problem: string;
  method: string;
  key_contributions: string[];
  sim_benchmarks: string[];
  real_robot: string;
  datasets: string;
  compute: string;
  results_headline: string;
  baselines: string[];
  limitations: string;
  code_release: string;
  relevance_detail: string;
  followup: string;
}
interface Paper {
  rank: number;
  title: string;
  title_zh?: string;
  score: number;
  authors: string[];
  source: string;
  arxiv_id: string | null;
  url: string;
  published: string | null;
  tldr: string;
  why: string;
  hits: string[];
  deep?: Deep;
}
interface Props {
  paper: Paper;
}
const { paper } = Astro.props;
const zh = paper.title_zh && paper.title_zh.trim() ? paper.title_zh : paper.title;
const authorsDisplay =
  paper.authors.length <= 5
    ? paper.authors.join(', ')
    : `${paper.authors.slice(0, 5).join(', ')}, … (+${paper.authors.length - 5})`;
const d = paper.deep;
const hasDeep = !!d && (d.problem || d.method || d.key_contributions.length > 0);
---
<article class="paper-card" data-score={paper.score}>
  <header class="paper-head">
    <span class="paper-rank">#{paper.rank.toString().padStart(2, '0')}</span>
    <span class="score-badge">{paper.score}/10</span>
  </header>

  <h2>{zh}</h2>
  {paper.title_zh && paper.title_zh.trim() && paper.title_zh !== paper.title && (
    <p class="title-en">{paper.title}</p>
  )}

  <p class="meta">
    <strong>作者</strong>{authorsDisplay}
  </p>
  <p class="meta">
    <strong>来源</strong><code>{paper.source}</code>
    {paper.arxiv_id && (
      <>
        <span class="sep">·</span>
        <strong>arXiv</strong>
        <a href={paper.url} target="_blank" rel="noopener noreferrer">
          <code>{paper.arxiv_id}</code>
        </a>
      </>
    )}
    {paper.published && (
      <>
        <span class="sep">·</span>
        <strong>发布</strong>{paper.published}
      </>
    )}
  </p>

  <div class="body">
    <p><strong>摘要.</strong>{paper.tldr}</p>
    <p><strong>为什么相关.</strong>{paper.why}</p>
  </div>

  {hasDeep && d && (
    <details class="deep">
      <summary>深度阅读 · full-text summary</summary>
      <dl>
        {d.problem && <><dt>解决的问题</dt><dd>{d.problem}</dd></>}
        {d.method && <><dt>方法</dt><dd>{d.method}</dd></>}
        {d.key_contributions.length > 0 && (
          <>
            <dt>关键贡献</dt>
            <dd>
              <ul>{d.key_contributions.map((c) => <li>{c}</li>)}</ul>
            </dd>
          </>
        )}
        {d.sim_benchmarks.length > 0 && (
          <>
            <dt>仿真 / Benchmark</dt>
            <dd class="chips">
              {d.sim_benchmarks.map((b) => <span class="chip">{b}</span>)}
            </dd>
          </>
        )}
        {d.real_robot && <><dt>真机实验</dt><dd>{d.real_robot}</dd></>}
        {d.datasets && <><dt>数据</dt><dd>{d.datasets}</dd></>}
        {d.compute && <><dt>算力 / 规模</dt><dd>{d.compute}</dd></>}
        {d.results_headline && <><dt>关键结果</dt><dd>{d.results_headline}</dd></>}
        {d.baselines.length > 0 && (
          <>
            <dt>主要 baseline</dt>
            <dd class="chips">
              {d.baselines.map((b) => <span class="chip">{b}</span>)}
            </dd>
          </>
        )}
        {d.limitations && <><dt>局限</dt><dd>{d.limitations}</dd></>}
        {d.code_release && <><dt>开源情况</dt><dd>{d.code_release}</dd></>}
        {d.relevance_detail && (
          <><dt>与你研究的连接</dt><dd>{d.relevance_detail}</dd></>
        )}
        {d.followup && <><dt>建议跟进</dt><dd>{d.followup}</dd></>}
      </dl>
    </details>
  )}

  {paper.hits.length > 0 && (
    <div class="hits">
      {paper.hits.map((h) => <span class="hit">{h}</span>)}
    </div>
  )}
</article>
